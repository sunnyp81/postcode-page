---
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import { getAllRegions, getAllCountyData, getAllPostcodeSlugs, getPostcodeData } from '../utils/data';
import { formatPriceFull, formatPrice } from '../utils/format';

const regions = getAllRegions().sort((a, b) => b.avgPrice - a.avgPrice);
const totalPostcodes = regions.reduce((s, r) => s + r.totalPostcodes, 0);
const nationalAvg = 287000;

// Top counties by price for a "featured areas" strip
const counties = getAllCountyData().sort((a, b) => b.avgPrice - a.avgPrice);
const topCounties = counties.slice(0, 6);

// Featured postcodes — pick a mix of well-known districts across regions
const featuredCodes = ['SW1A', 'GU1', 'M1', 'B1', 'LS1', 'EH1', 'BS1', 'OX1'];
const featuredPostcodes = featuredCodes
  .map(c => getPostcodeData(c.toLowerCase()))
  .filter(Boolean) as NonNullable<ReturnType<typeof getPostcodeData>>[];

const guides = [
  { href: '/guides/average-house-price-uk/', title: 'Average UK House Prices 2026', tag: 'House Prices', desc: 'National, regional and county averages from Land Registry.' },
  { href: '/guides/cheapest-places-to-live-england/', title: 'Cheapest Places to Live in England', tag: 'Affordability', desc: 'The 30 most affordable postcode districts ranked.' },
  { href: '/guides/safest-areas-england-wales/', title: 'Safest Areas in England & Wales', tag: 'Crime & Safety', desc: 'Lowest crime rate districts from Police.uk data.' },
  { href: '/guides/best-areas-for-families/', title: 'Best Areas for Families 2026', tag: 'Family Living', desc: 'Scored on schools, crime, and house prices combined.' },
  { href: '/guides/fastest-rising-house-prices/', title: 'Fastest-Rising House Prices', tag: 'Price Trends', desc: '1-year and 5-year growth ranked by postcode district.' },
];
---

<Base
  title="Postcode.Page — UK Postcode Data: House Prices, Crime, Schools & More"
  description="Free property prices, crime rates, school ratings, broadband speeds and demographics for every UK postcode district. Updated monthly from official government sources."
  schema={[
    {
      "@type": "WebSite",
      "name": "Postcode.Page",
      "url": "https://postcode.page/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://postcode.page/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "Postcode.Page",
      "url": "https://postcode.page/",
      "description": "Free UK postcode data from official government sources. Property prices, crime, schools, broadband, and demographics for every postcode district."
    }
  ]}
>
  <Header />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 opacity-15 dot-grid" aria-hidden="true"/>
    <div class="absolute -top-40 -right-20 w-[500px] h-[500px] rounded-full opacity-8 blur-[120px]"
         style="background: radial-gradient(circle, hsl(168, 55%, 45%), transparent 70%)" aria-hidden="true"/>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 rounded-full opacity-5 blur-[100px]"
         style="background: radial-gradient(circle, hsl(210, 60%, 60%), transparent 70%)" aria-hidden="true"/>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">
      <p class="font-mono text-accent-400 text-sm tracking-widest uppercase mb-4">Free · Updated Monthly · Official Sources</p>
      <h1 class="font-display font-700 text-5xl sm:text-7xl text-white leading-none tracking-tight mb-4">
        Every UK postcode.<br/>
        <span class="text-accent-400">One page of data.</span>
      </h1>
      <p class="text-brand-300 text-lg sm:text-xl max-w-xl mx-auto mt-6 leading-relaxed">
        Property prices, crime rates, school ratings, broadband speeds, and demographics — all in one place, free forever.
      </p>

      <!-- Search -->
      <form action="/search" method="get" class="mt-10 max-w-md mx-auto" role="search">
        <label for="hero-search" class="sr-only">Search UK postcodes</label>
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            id="hero-search"
            type="search"
            name="q"
            placeholder="Enter a postcode (e.g. GU1, SW1A, M1)"
            autocomplete="off"
            class="w-full pl-12 pr-32 py-4 text-brand-900 bg-white rounded-xl text-base focus:outline-none focus:ring-2 focus:ring-accent-400 shadow-2xl"
          />
          <button
            type="submit"
            class="absolute right-2 top-1/2 -translate-y-1/2 px-5 py-2.5 bg-accent-400 text-white rounded-lg font-600 text-sm hover:bg-accent-500 transition-colors"
          >
            Search
          </button>
        </div>
        <p class="text-brand-500 text-xs mt-3">Try: <a href="/gu1/" class="text-brand-400 hover:text-white transition-colors">GU1</a> · <a href="/sw1a/" class="text-brand-400 hover:text-white transition-colors">SW1A</a> · <a href="/m1/" class="text-brand-400 hover:text-white transition-colors">M1</a> · <a href="/bs1/" class="text-brand-400 hover:text-white transition-colors">BS1</a></p>
      </form>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="bg-brand-900 border-b border-brand-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-xs text-brand-400">
      <span class="font-600 text-brand-300">Data from official sources:</span>
      <span>HM Land Registry</span>
      <span>·</span>
      <span>data.police.uk</span>
      <span>·</span>
      <span>Ofsted</span>
      <span>·</span>
      <span>Ofcom</span>
      <span>·</span>
      <span>Department for Education</span>
      <span class="font-600 text-brand-300 ml-4">{totalPostcodes} postcode districts</span>
    </div>
  </div>

  <main>

    <!-- BROWSE BY REGION -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-display font-700 text-brand-900">Browse by Region</h2>
        <p class="text-brand-500 mt-2">Select a region to explore postcode districts, area data, and house prices.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {regions.map(r => {
          const vsNat = ((r.avgPrice - nationalAvg) / nationalAvg * 100);
          return (
            <a
              href={`/regions/${r.slug}/`}
              class="card p-5 hover:-translate-y-0.5 transition-transform duration-200 group block"
            >
              <div class="flex items-start justify-between">
                <div>
                  <h3 class="font-display font-600 text-brand-900 group-hover:text-accent-500 transition-colors">{r.label}</h3>
                  <p class="text-sm text-brand-400 mt-0.5">{r.totalPostcodes} postcode districts</p>
                </div>
                <svg class="w-4 h-4 text-brand-300 group-hover:text-accent-400 transition-colors mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
              <div class="flex items-baseline gap-2 mt-3">
                <span class="font-mono font-700 text-brand-900 text-lg">{formatPrice(r.avgPrice)}</span>
                <span class="text-xs text-brand-400">avg price</span>
                <span class={`ml-auto font-mono text-sm font-600 ${vsNat >= 0 ? 'text-rose-600' : 'text-accent-600'}`}>
                  {vsNat >= 0 ? '+' : ''}{vsNat.toFixed(0)}% vs national
                </span>
              </div>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a href="/guides/" class="inline-flex items-center gap-2 text-accent-500 hover:text-accent-600 font-500 text-sm transition-colors">
          View average house prices by region →
        </a>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="bg-brand-50 border-y border-brand-100 py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-display font-700 text-brand-900">Everything you need to research an area</h2>
          <p class="text-brand-500 mt-2">Six data categories, all on one page, all from official UK sources.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            {
              icon: '🏠',
              title: 'House Prices',
              desc: 'Average sold prices, price by property type, and year-on-year change. Source: HM Land Registry.',
            },
            {
              icon: '🚔',
              title: 'Crime Rates',
              desc: 'Total crimes per 1,000 residents vs the national average, broken down by category. Source: data.police.uk.',
            },
            {
              icon: '🎓',
              title: 'School Ratings',
              desc: 'Number of schools nearby and Ofsted inspection grades — Outstanding, Good, and more. Source: Ofsted.',
            },
            {
              icon: '📡',
              title: 'Broadband Speeds',
              desc: 'Average download speeds and superfast/full-fibre coverage percentage. Source: Ofcom.',
            },
            {
              icon: '👥',
              title: 'Demographics',
              desc: 'Population, median age, tenure breakdown — owner-occupied vs rented. Source: ONS Census 2021.',
            },
            {
              icon: '🏛️',
              title: 'Council Tax',
              desc: 'Band D council tax rate for the local authority covering the postcode district.',
            },
          ].map(item => (
            <div class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm">
              <div class="text-2xl mb-3">{item.icon}</div>
              <h3 class="font-display font-600 text-brand-900 mb-1">{item.title}</h3>
              <p class="text-sm text-brand-500 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURED COUNTIES -->
    {topCounties.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
        <div class="flex items-baseline justify-between mb-8">
          <div>
            <h2 class="text-2xl font-display font-700 text-brand-900">Most Expensive Counties</h2>
            <p class="text-brand-500 text-sm mt-1">Average house prices by county, based on recent Land Registry sales.</p>
          </div>
          <a href="/guides/" class="text-accent-500 hover:text-accent-600 text-sm font-500 shrink-0">All regions →</a>
        </div>
        <div class="bg-white border border-brand-100 rounded-xl overflow-hidden shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-brand-50 border-b border-brand-100">
                <th class="text-left px-4 py-3 text-brand-600 font-600">County</th>
                <th class="text-right px-4 py-3 text-brand-600 font-600">Avg Price</th>
                <th class="text-right px-4 py-3 text-brand-600 font-600 hidden sm:table-cell">vs National</th>
                <th class="text-right px-4 py-3 text-brand-600 font-600 hidden md:table-cell">Districts</th>
              </tr>
            </thead>
            <tbody>
              {topCounties.map((c, i) => {
                const vsNat = ((c.avgPrice - nationalAvg) / nationalAvg * 100);
                return (
                  <tr class={`border-b border-brand-50 hover:bg-brand-50/50 transition-colors ${i % 2 === 0 ? '' : 'bg-brand-50/30'}`}>
                    <td class="px-4 py-3">
                      <a href={`/counties/${c.slug}/`} class="text-accent-500 hover:text-accent-600 font-500 transition-colors capitalize">{c.label}</a>
                    </td>
                    <td class="px-4 py-3 text-right font-mono font-600 text-brand-800">{formatPriceFull(c.avgPrice)}</td>
                    <td class="px-4 py-3 text-right hidden sm:table-cell">
                      <span class={`text-xs font-600 ${vsNat >= 0 ? 'text-rose-600' : 'text-accent-600'}`}>
                        {vsNat >= 0 ? '+' : ''}{vsNat.toFixed(0)}%
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right text-brand-500 hidden md:table-cell">{c.postcodeCount}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- FEATURED POSTCODES -->
    {featuredPostcodes.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 pb-4">
        <div class="flex items-baseline justify-between mb-6">
          <div>
            <h2 class="text-2xl font-display font-700 text-brand-900">Popular Areas</h2>
            <p class="text-brand-500 text-sm mt-1">Quick links to well-known UK postcode districts.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {featuredPostcodes.map(d => (
            <a href={`/${d.code.toLowerCase()}/`} class="bg-white border border-brand-100 rounded-xl p-4 shadow-sm hover:border-accent-300 hover:shadow-md transition-all group">
              <p class="font-mono font-700 text-xl text-brand-900 group-hover:text-accent-500 transition-colors">{d.code}</p>
              <p class="text-brand-400 text-xs mt-0.5 truncate">{d.name}</p>
              <p class="font-mono font-600 text-brand-800 text-sm mt-2">{formatPrice(d.property.avgPrice)}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- LATEST GUIDES -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <div class="flex items-baseline justify-between mb-6">
        <div>
          <h2 class="text-2xl font-display font-700 text-brand-900">Property Guides</h2>
          <p class="text-brand-500 text-sm mt-1">Data-driven insights from official UK sources.</p>
        </div>
        <a href="/guides/" class="text-accent-500 hover:text-accent-600 text-sm font-500 shrink-0">All guides →</a>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {guides.map(g => (
          <a href={g.href} class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm hover:border-accent-300 hover:shadow-md transition-all group block">
            <span class="text-xs font-600 text-accent-500 uppercase tracking-wide">{g.tag}</span>
            <h3 class="font-display font-600 text-brand-900 mt-1 mb-2 group-hover:text-accent-500 transition-colors text-sm">{g.title}</h3>
            <p class="text-brand-500 text-xs">{g.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- DATA FRESHNESS -->
    <section class="bg-brand-50 border-t border-brand-100 py-12 text-center">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-50 border border-green-200 rounded-full text-green-700 text-xs font-600 mb-4">
          <span class="w-1.5 h-1.5 bg-green-500 rounded-full"/>
          Updated March 2026
        </div>
        <h2 class="text-2xl font-display font-600 text-brand-900">Always current. Always free.</h2>
        <p class="text-brand-500 mt-2 max-w-lg mx-auto">
          We refresh house price and crime data every month from official government sources. No subscription. No paywall. No sign-up required.
        </p>
        <a href="/methodology/" class="inline-flex items-center gap-1.5 text-accent-500 hover:text-accent-400 font-500 text-sm mt-4 transition-colors">
          Learn about our data methodology →
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
