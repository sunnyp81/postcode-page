---
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
---
<Base title="Privacy Policy — postcode.page" description="Privacy policy for postcode.page.">
  <Header />
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1>Privacy Policy</h1>
    <p class="text-brand-600 mt-4 max-w-2xl">postcode.page does not collect personal data. We use no tracking cookies. Analytics are privacy-preserving and aggregate-only.</p>
  </main>
  <Footer />
</Base>
