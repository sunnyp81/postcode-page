---
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const schema = [
  {
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate,
    "dateModified": post.data.updatedDate || post.data.pubDate,
    "author": {
      "@type": "Organization",
      "name": "Postcode.Page",
      "url": "https://postcode.page/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Postcode.Page",
      "url": "https://postcode.page/"
    }
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://postcode.page/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://postcode.page/blog/" },
      { "@type": "ListItem", "position": 3, "name": post.data.title },
    ]
  }
];
---

<Base
  title={`${post.data.title} — Postcode.Page`}
  description={post.data.description}
  schema={schema}
>
  <Header />

  <div class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 opacity-20 dot-grid" aria-hidden="true"/>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <nav class="flex items-center gap-2 text-brand-400 text-sm mb-4">
        <a href="/blog/" class="hover:text-accent-400 transition-colors">Blog</a>
        <span>/</span>
        <span class="text-brand-300">{post.data.category}</span>
      </nav>
      <span class="text-xs font-600 text-accent-400 uppercase tracking-wide">{post.data.category}</span>
      <h1 class="font-display font-700 text-3xl sm:text-4xl text-white tracking-tight leading-tight mt-2">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-brand-400 text-sm mt-4">
        <time datetime={post.data.pubDate}>
          {new Date(post.data.pubDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <span>·</span>
        <span>{post.data.readTime} min read</span>
      </div>
    </div>
  </div>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <article class="prose prose-brand max-w-none
      prose-headings:font-display prose-headings:font-600 prose-headings:text-brand-900
      prose-p:text-brand-700 prose-p:leading-relaxed
      prose-a:text-accent-500 prose-a:no-underline hover:prose-a:underline
      prose-strong:text-brand-800
      prose-li:text-brand-700
      prose-table:text-sm
      prose-th:text-brand-600 prose-th:font-600 prose-th:bg-brand-50 prose-th:p-3
      prose-td:text-brand-700 prose-td:p-3 prose-td:border-brand-100
      prose-hr:border-brand-100
      prose-code:text-accent-600 prose-code:bg-brand-50 prose-code:px-1 prose-code:rounded
    ">
      <Content />
    </article>

    <!-- CTA -->
    <div class="mt-12 bg-brand-50 border border-brand-200 rounded-xl p-6 text-center">
      <p class="font-display font-600 text-brand-900 text-lg mb-2">Research any UK postcode</p>
      <p class="text-brand-500 text-sm mb-4">House prices, crime, schools, broadband, council tax and demographics — free for every district in England.</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-400 text-white rounded-lg font-600 text-sm hover:bg-accent-500 transition-colors">
        Search a postcode →
      </a>
    </div>

    <!-- Related posts -->
    <div class="mt-8">
      <h2 class="font-display font-600 text-xl text-brand-900 mb-4">More guides</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/blog/" class="text-sm px-3 py-1.5 bg-white border border-brand-100 text-brand-600 rounded-lg hover:border-accent-300 hover:text-accent-600 transition-colors">← All blog posts</a>
        <a href="/guides/" class="text-sm px-3 py-1.5 bg-white border border-brand-100 text-brand-600 rounded-lg hover:border-accent-300 hover:text-accent-600 transition-colors">Property guides →</a>
        <a href="/methodology/" class="text-sm px-3 py-1.5 bg-white border border-brand-100 text-brand-600 rounded-lg hover:border-accent-300 hover:text-accent-600 transition-colors">Data methodology →</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
