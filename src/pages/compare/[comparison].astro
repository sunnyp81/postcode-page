---
import Base from '../../layouts/Base.astro';
import Header from '../../components/global/Header.astro';
import Footer from '../../components/global/Footer.astro';
import CompareSVG from '../../components/svg/CompareSVG.astro';
import { getPostcodeData } from '../../utils/data';
import { formatPriceFull } from '../../utils/format';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const pairs = JSON.parse(
    readFileSync(join(process.cwd(), 'data', 'comparison-pairs.json'), 'utf-8')
  ) as string[];
  return pairs.map(pair => ({ params: { comparison: pair.toLowerCase() } }));
}

const { comparison } = Astro.params;
const [codeA, codeB] = comparison.split('-vs-').map(c => c.toUpperCase());

const a = getPostcodeData(codeA.toLowerCase());
const b = getPostcodeData(codeB.toLowerCase());

if (!a || !b) return Astro.redirect('/');

function label(code: string, data: typeof a) {
  return data?.name !== code ? `${code} (${data?.name})` : code;
}

function winner(aVal: number, bVal: number, lowerIsBetter = false) {
  if (lowerIsBetter) return aVal < bVal ? 'a' : aVal > bVal ? 'b' : 'tie';
  return aVal > bVal ? 'a' : aVal < bVal ? 'b' : 'tie';
}

const rows = [
  {
    label: 'Average House Price',
    aVal: a.property.avgPrice,
    bVal: b.property.avgPrice,
    format: (v: number) => formatPriceFull(v),
    win: winner(a.property.avgPrice, b.property.avgPrice, false),
    winLabel: 'higher',
  },
  {
    label: '1-Year Price Change',
    aVal: a.property.priceChange1y,
    bVal: b.property.priceChange1y,
    format: (v: number) => v ? `${v > 0 ? '+' : ''}${v.toFixed(1)}%` : 'N/A',
    win: winner(a.property.priceChange1y || 0, b.property.priceChange1y || 0, false),
    winLabel: 'faster growth',
  },
  {
    label: 'Crime Rate (per 1,000)',
    aVal: a.crime.totalPer1000,
    bVal: b.crime.totalPer1000,
    format: (v: number) => v.toFixed(1),
    win: winner(a.crime.totalPer1000, b.crime.totalPer1000, true),
    winLabel: 'lower crime',
  },
  {
    label: 'Schools (Good+)',
    aVal: a.schools.count > 0 ? Math.round((a.schools.outstanding + a.schools.good) / a.schools.count * 100) : 0,
    bVal: b.schools.count > 0 ? Math.round((b.schools.outstanding + b.schools.good) / b.schools.count * 100) : 0,
    format: (v: number) => `${v}%`,
    win: winner(
      a.schools.count > 0 ? (a.schools.outstanding + a.schools.good) / a.schools.count : 0,
      b.schools.count > 0 ? (b.schools.outstanding + b.schools.good) / b.schools.count : 0,
      false
    ),
    winLabel: 'better schools',
  },
  {
    label: 'Avg Broadband Speed',
    aVal: a.broadband.avgDownload,
    bVal: b.broadband.avgDownload,
    format: (v: number) => `${v.toFixed(0)} Mbps`,
    win: winner(a.broadband.avgDownload, b.broadband.avgDownload, false),
    winLabel: 'faster broadband',
  },
  {
    label: 'Council Tax Band D',
    aVal: a.councilTax.bandD,
    bVal: b.councilTax.bandD,
    format: (v: number) => formatPriceFull(v),
    win: winner(a.councilTax.bandD, b.councilTax.bandD, true),
    winLabel: 'lower council tax',
  },
  {
    label: 'Owner-Occupied',
    aVal: a.demographics.ownerOccupied,
    bVal: b.demographics.ownerOccupied,
    format: (v: number) => `${v}%`,
    win: winner(a.demographics.ownerOccupied, b.demographics.ownerOccupied, false),
    winLabel: 'more owner-occupied',
  },
  {
    label: 'Superfast Broadband',
    aVal: a.broadband.superfastPct,
    bVal: b.broadband.superfastPct,
    format: (v: number) => `${v}%`,
    win: winner(a.broadband.superfastPct, b.broadband.superfastPct, false),
    winLabel: 'better coverage',
  },
];

const aWins = rows.filter(r => r.win === 'a').length;
const bWins = rows.filter(r => r.win === 'b').length;
---
<Base
  title={`${codeA} vs ${codeB} — House Prices, Crime & Schools Compared`}
  description={`Side-by-side comparison of ${codeA} and ${codeB}: house prices, crime rates, school ratings, broadband speeds and council tax. Which area is better?`}
>
  <Header />

  <div class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 opacity-20 dot-grid" aria-hidden="true"/>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <p class="font-mono text-accent-400 text-sm font-500 tracking-widest uppercase mb-2">Compare</p>
      <h1 class="font-display font-700 text-4xl sm:text-5xl text-white tracking-tight leading-tight">
        {codeA} vs {codeB}
      </h1>
      <p class="text-brand-300 text-lg mt-3">
        {label(codeA, a)} vs {label(codeB, b)} — house prices, crime, schools, broadband and council tax compared.
      </p>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <!-- Comparison illustration -->
    <div class="mb-8 flex justify-center">
      <CompareSVG />
    </div>

    <!-- Score banner -->
    <section class="grid grid-cols-3 gap-4 mb-10">
      <div class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm text-center">
        <p class="text-xs font-600 text-brand-500 uppercase tracking-wide mb-2">{codeA} wins</p>
        <p class="font-display font-700 text-4xl text-accent-500">{aWins}</p>
        <p class="text-brand-500 text-sm mt-1">of {rows.length} categories</p>
      </div>
      <div class="bg-brand-50 rounded-xl p-5 text-center flex items-center justify-center">
        <span class="font-display font-700 text-2xl text-brand-400">vs</span>
      </div>
      <div class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm text-center">
        <p class="text-xs font-600 text-brand-500 uppercase tracking-wide mb-2">{codeB} wins</p>
        <p class="font-display font-700 text-4xl text-accent-500">{bWins}</p>
        <p class="text-brand-500 text-sm mt-1">of {rows.length} categories</p>
      </div>
    </section>

    <!-- Comparison table -->
    <section class="mb-12">
      <div class="bg-white border border-brand-100 rounded-xl overflow-hidden shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-brand-50 border-b border-brand-100">
              <th class="text-left px-4 py-3 text-brand-600 font-600 w-1/3">Metric</th>
              <th class="text-center px-4 py-3 text-brand-600 font-600 w-1/3">
                <a href={`/${codeA.toLowerCase()}/`} class="text-accent-500 hover:underline">{codeA}</a>
              </th>
              <th class="text-center px-4 py-3 text-brand-600 font-600 w-1/3">
                <a href={`/${codeB.toLowerCase()}/`} class="text-accent-500 hover:underline">{codeB}</a>
              </th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, i) => (
              <tr class={`border-b border-brand-50 ${i % 2 === 0 ? '' : 'bg-brand-50/20'}`}>
                <td class="px-4 py-3 text-brand-700 font-500">{row.label}</td>
                <td class={`px-4 py-3 text-center font-mono font-600 ${row.win === 'a' ? 'text-accent-600 bg-accent-50/50' : 'text-brand-600'}`}>
                  {row.format(row.aVal)}
                  {row.win === 'a' && <span class="ml-1 text-xs text-accent-500">✓</span>}
                </td>
                <td class={`px-4 py-3 text-center font-mono font-600 ${row.win === 'b' ? 'text-accent-600 bg-accent-50/50' : 'text-brand-600'}`}>
                  {row.format(row.bVal)}
                  {row.win === 'b' && <span class="ml-1 text-xs text-accent-500">✓</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Price history side by side -->
    <section class="mb-12 grid md:grid-cols-2 gap-6">
      <div class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm">
        <h3 class="font-display font-600 text-brand-800 mb-3">
          <a href={`/${codeA.toLowerCase()}/`} class="hover:text-accent-500 transition-colors">{codeA} — Key Facts</a>
        </h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between"><dt class="text-brand-500">County</dt><dd class="font-500 capitalize">{a.county.replace(/-/g,' ')}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Region</dt><dd class="font-500 capitalize">{a.region.replace(/-/g,' ')}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Transactions (12m)</dt><dd class="font-500">{a.property.transactions12m.toLocaleString()}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Full fibre</dt><dd class="font-500">{a.broadband.fullFibrePct}%</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Schools</dt><dd class="font-500">{a.schools.count} total</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Owner-occupied</dt><dd class="font-500">{a.demographics.ownerOccupied}%</dd></div>
        </dl>
        <a href={`/${codeA.toLowerCase()}/`} class="mt-4 block text-center text-sm text-accent-500 hover:text-accent-600 font-500 border border-accent-200 rounded-lg py-2 hover:bg-accent-50 transition-colors">
          Full {codeA} profile →
        </a>
      </div>
      <div class="bg-white border border-brand-100 rounded-xl p-5 shadow-sm">
        <h3 class="font-display font-600 text-brand-800 mb-3">
          <a href={`/${codeB.toLowerCase()}/`} class="hover:text-accent-500 transition-colors">{codeB} — Key Facts</a>
        </h3>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between"><dt class="text-brand-500">County</dt><dd class="font-500 capitalize">{b.county.replace(/-/g,' ')}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Region</dt><dd class="font-500 capitalize">{b.region.replace(/-/g,' ')}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Transactions (12m)</dt><dd class="font-500">{b.property.transactions12m.toLocaleString()}</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Full fibre</dt><dd class="font-500">{b.broadband.fullFibrePct}%</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Schools</dt><dd class="font-500">{b.schools.count} total</dd></div>
          <div class="flex justify-between"><dt class="text-brand-500">Owner-occupied</dt><dd class="font-500">{b.demographics.ownerOccupied}%</dd></div>
        </dl>
        <a href={`/${codeB.toLowerCase()}/`} class="mt-4 block text-center text-sm text-accent-500 hover:text-accent-600 font-500 border border-accent-200 rounded-lg py-2 hover:bg-accent-50 transition-colors">
          Full {codeB} profile →
        </a>
      </div>
    </section>

    <!-- Nearby comparisons -->
    <section>
      <h2 class="font-display font-700 text-xl text-brand-800 mb-4">Other comparisons</h2>
      <div class="flex flex-wrap gap-2">
        {[...a.adjacent, ...b.adjacent]
          .filter((c, i, arr) => arr.indexOf(c) === i && c !== codeA && c !== codeB)
          .slice(0, 8)
          .map(code => (
            <a href={`/compare/${[codeA, code].sort().join('-vs-').toLowerCase()}/`}
               class="text-sm px-3 py-1.5 bg-brand-50 text-brand-600 rounded-lg hover:bg-accent-50 hover:text-accent-600 transition-colors border border-brand-100">
              {codeA} vs {code}
            </a>
          ))
        }
        {[...b.adjacent]
          .filter(c => c !== codeA && c !== codeB)
          .slice(0, 4)
          .map(code => (
            <a href={`/compare/${[codeB, code].sort().join('-vs-').toLowerCase()}/`}
               class="text-sm px-3 py-1.5 bg-brand-50 text-brand-600 rounded-lg hover:bg-accent-50 hover:text-accent-600 transition-colors border border-brand-100">
              {codeB} vs {code}
            </a>
          ))
        }
      </div>
    </section>

  </main>

  <Footer />
</Base>
