---
import Base from '../layouts/Base.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
---
<Base title="About — postcode.page" description="About postcode.page — free UK postcode data.">
  <Header />
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <h1>About postcode.page</h1>
    <p class="text-brand-600 mt-4 max-w-2xl leading-relaxed">
      postcode.page is a free resource providing comprehensive data for every UK postcode district. Our data is sourced from official UK government datasets and updated monthly.
    </p>
    <p class="text-brand-600 mt-4 max-w-2xl leading-relaxed">
      Contact: <a href="mailto:hello@postcode.page" class="text-accent-500 hover:underline">hello@postcode.page</a>
    </p>
  </main>
  <Footer />
</Base>
