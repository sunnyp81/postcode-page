---
/**
 * Suburban scene SVG — houses with gardens, driveways, a school sign.
 * For suburban postcode pages. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 800 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-2xl mx-auto" role="img" aria-label="Illustration of a suburban street with houses, gardens and a school sign">
  <defs>
    <linearGradient id="sub-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(200, 50%, 92%)"/>
      <stop offset="100%" stop-color="hsl(200, 40%, 85%)"/>
    </linearGradient>
    <linearGradient id="sub-grass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(130, 40%, 55%)"/>
      <stop offset="100%" stop-color="hsl(130, 45%, 45%)"/>
    </linearGradient>
  </defs>

  <!-- Sky -->
  <rect width="800" height="300" fill="url(#sub-sky)"/>

  <!-- Clouds -->
  <g opacity="0.35">
    <ellipse cx="180" cy="50" rx="55" ry="20" fill="white"/>
    <ellipse cx="210" cy="45" rx="35" ry="14" fill="white"/>
    <ellipse cx="500" cy="35" rx="50" ry="18" fill="white"/>
    <ellipse cx="530" cy="30" rx="30" ry="12" fill="white"/>
    <ellipse cx="720" cy="55" rx="40" ry="14" fill="white"/>
  </g>

  <!-- Ground -->
  <rect x="0" y="225" width="800" height="75" fill="url(#sub-grass)"/>

  <!-- Pavement -->
  <rect x="0" y="225" width="800" height="8" fill="hsl(30, 10%, 78%)" opacity="0.7"/>

  <!-- Road -->
  <rect x="0" y="233" width="800" height="18" fill="hsl(0, 0%, 40%)" opacity="0.3"/>

  <!-- Road markings -->
  <g opacity="0.4">
    <rect x="60" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="160" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="260" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="360" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="460" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="560" y="241" width="35" height="2.5" rx="1" fill="white"/>
    <rect x="660" y="241" width="35" height="2.5" rx="1" fill="white"/>
  </g>

  <!-- House 1 — Semi with bay window -->
  <g transform="translate(30, 90)">
    <rect x="0" y="35" width="120" height="100" rx="2" fill="hsl(15, 50%, 60%)"/>
    <polygon points="-5,38 60,5 125,38" fill="hsl(210, 40%, 30%)"/>
    <!-- Windows -->
    <rect x="15" y="55" width="25" height="25" rx="1" fill="hsl(210, 40%, 92%)"/>
    <rect x="80" y="55" width="25" height="25" rx="1" fill="hsl(210, 40%, 92%)"/>
    <!-- Glazing bars -->
    <line x1="27.5" y1="55" x2="27.5" y2="80" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <line x1="15" y1="67.5" x2="40" y2="67.5" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <!-- Door -->
    <rect x="48" y="95" width="24" height="40" rx="1" fill="hsl(168, 55%, 42%)"/>
    <circle cx="66" cy="117" r="2" fill="hsl(42, 70%, 50%)"/>
    <!-- Chimney -->
    <rect x="90" y="8" width="12" height="24" fill="hsl(15, 45%, 50%)"/>
    <rect x="88" y="6" width="16" height="4" fill="hsl(15, 40%, 42%)"/>
    <!-- Garden hedge -->
    <rect x="-10" y="132" width="140" height="8" rx="4" fill="hsl(140, 35%, 40%)" opacity="0.6"/>
    <!-- Driveway -->
    <rect x="90" y="135" width="35" height="20" fill="hsl(30, 10%, 70%)" opacity="0.4" rx="1"/>
  </g>

  <!-- House 2 — Detached with garage -->
  <g transform="translate(210, 80)">
    <rect x="0" y="40" width="140" height="105" rx="2" fill="hsl(40, 20%, 88%)"/>
    <polygon points="-5,43 70,5 145,43" fill="hsl(0, 35%, 42%)"/>
    <!-- Windows -->
    <rect x="18" y="60" width="30" height="30" rx="1" fill="hsl(210, 40%, 92%)"/>
    <rect x="92" y="60" width="30" height="30" rx="1" fill="hsl(210, 40%, 92%)"/>
    <!-- Cross glazing -->
    <line x1="33" y1="60" x2="33" y2="90" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <line x1="18" y1="75" x2="48" y2="75" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <line x1="107" y1="60" x2="107" y2="90" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <line x1="92" y1="75" x2="122" y2="75" stroke="hsl(210, 30%, 75%)" stroke-width="1"/>
    <!-- Door with porch -->
    <rect x="55" y="105" width="30" height="40" rx="1" fill="hsl(210, 55%, 15%)"/>
    <rect x="52" y="102" width="36" height="6" fill="hsl(210, 40%, 30%)"/>
    <circle cx="79" cy="127" r="2" fill="hsl(42, 70%, 50%)"/>
    <!-- Garage -->
    <rect x="120" y="110" width="40" height="35" fill="hsl(40, 15%, 82%)"/>
    <rect x="123" y="113" width="34" height="30" rx="1" fill="hsl(210, 20%, 65%)" opacity="0.4"/>
    <!-- Garden path -->
    <rect x="65" y="145" width="10" height="16" fill="hsl(30, 10%, 75%)" opacity="0.4" rx="1"/>
  </g>

  <!-- House 3 — Modern new-build -->
  <g transform="translate(430, 85)">
    <rect x="0" y="30" width="130" height="110" rx="3" fill="hsl(210, 15%, 80%)"/>
    <rect x="0" y="26" width="130" height="8" fill="hsl(210, 30%, 35%)"/>
    <!-- Large windows -->
    <rect x="12" y="45" width="40" height="35" rx="2" fill="hsl(210, 40%, 92%)"/>
    <rect x="78" y="45" width="40" height="35" rx="2" fill="hsl(210, 40%, 92%)"/>
    <!-- Door -->
    <rect x="50" y="100" width="30" height="40" rx="2" fill="hsl(168, 50%, 40%)"/>
    <rect x="52" y="102" width="12" height="16" rx="1" fill="hsl(210, 40%, 92%)" opacity="0.5"/>
    <!-- Solar panels on roof -->
    <g opacity="0.3">
      <rect x="15" y="12" width="22" height="12" rx="1" fill="hsl(210, 50%, 30%)"/>
      <rect x="42" y="12" width="22" height="12" rx="1" fill="hsl(210, 50%, 30%)"/>
    </g>
  </g>

  <!-- House 4 — Bungalow -->
  <g transform="translate(620, 120)">
    <rect x="0" y="30" width="130" height="75" rx="2" fill="hsl(20, 45%, 65%)"/>
    <polygon points="-8,33 65,5 138,33" fill="hsl(210, 40%, 30%)"/>
    <!-- Windows -->
    <rect x="12" y="45" width="28" height="25" rx="1" fill="hsl(210, 40%, 92%)"/>
    <rect x="90" y="45" width="28" height="25" rx="1" fill="hsl(210, 40%, 92%)"/>
    <!-- Door -->
    <rect x="52" y="65" width="26" height="40" rx="1" fill="hsl(168, 55%, 42%)"/>
    <circle cx="72" cy="87" r="2" fill="hsl(42, 70%, 50%)"/>
  </g>

  <!-- Trees -->
  <g transform="translate(170, 120)">
    <rect x="8" y="60" width="8" height="35" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="12" cy="45" rx="20" ry="25" fill="hsl(140, 40%, 42%)"/>
    <ellipse cx="18" cy="38" rx="14" ry="18" fill="hsl(145, 45%, 48%)"/>
  </g>
  <g transform="translate(395, 125)">
    <rect x="6" y="50" width="7" height="30" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="9" cy="38" rx="16" ry="20" fill="hsl(140, 40%, 42%)"/>
    <ellipse cx="15" cy="32" rx="10" ry="14" fill="hsl(145, 45%, 48%)"/>
  </g>
  <g transform="translate(590, 135)">
    <rect x="5" y="45" width="6" height="25" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="8" cy="35" rx="14" ry="18" fill="hsl(140, 40%, 42%)"/>
  </g>

  <!-- School sign -->
  <g transform="translate(760, 195)">
    <rect x="0" y="0" width="2" height="30" fill="hsl(210, 20%, 55%)"/>
    <rect x="-10" y="-3" width="24" height="16" rx="2" fill="hsl(42, 70%, 55%)"/>
    <!-- Silhouette of children -->
    <circle cx="0" cy="3" r="2.5" fill="hsl(42, 50%, 35%)"/>
    <circle cx="7" cy="4" r="2" fill="hsl(42, 50%, 35%)"/>
  </g>
</svg>
