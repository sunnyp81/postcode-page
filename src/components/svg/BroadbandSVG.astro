---
/**
 * Broadband SVG — WiFi signal, router, speed gauge.
 * For the broadband blog post. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 600 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-md mx-auto" role="img" aria-label="Illustration of broadband speed with a router and signal waves">
  <defs>
    <linearGradient id="bb-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 94%)"/>
    </linearGradient>
  </defs>

  <rect width="600" height="200" rx="12" fill="url(#bb-bg)"/>

  <!-- Router -->
  <g transform="translate(60, 80)">
    <rect x="0" y="20" width="100" height="50" rx="6" fill="hsl(210, 30%, 35%)"/>
    <rect x="0" y="20" width="100" height="8" rx="6" fill="hsl(210, 35%, 30%)"/>
    <!-- LEDs -->
    <circle cx="15" cy="45" r="3" fill="hsl(168, 70%, 50%)"/>
    <circle cx="30" cy="45" r="3" fill="hsl(168, 70%, 50%)"/>
    <circle cx="45" cy="45" r="3" fill="hsl(168, 70%, 50%)" opacity="0.5"/>
    <circle cx="60" cy="45" r="3" fill="hsl(42, 70%, 55%)" opacity="0.5"/>
    <!-- Antenna -->
    <rect x="25" y="0" width="3" height="22" fill="hsl(210, 25%, 50%)" rx="1.5"/>
    <circle cx="26.5" cy="0" r="3" fill="hsl(210, 25%, 50%)"/>
    <rect x="72" y="3" width="3" height="19" fill="hsl(210, 25%, 50%)" rx="1.5" transform="rotate(15, 73.5, 12)"/>
    <circle cx="73" cy="2" r="3" fill="hsl(210, 25%, 50%)"/>
  </g>

  <!-- WiFi signal arcs -->
  <g transform="translate(110, 50)" stroke="hsl(168, 55%, 45%)" fill="none" stroke-width="2.5" stroke-linecap="round">
    <path d="M-12 0 A15 15 0 0 1 12 0" opacity="0.3"/>
    <path d="M-20 -8 A25 25 0 0 1 20 -8" opacity="0.2"/>
    <path d="M-28 -16 A35 35 0 0 1 28 -16" opacity="0.12"/>
  </g>

  <!-- Speed gauge -->
  <g transform="translate(320, 40)">
    <!-- Gauge background -->
    <path d="M20 100 A80 80 0 0 1 180 100" stroke="hsl(210, 25%, 88%)" stroke-width="12" fill="none" stroke-linecap="round"/>
    <!-- Gauge fill (fast) -->
    <path d="M20 100 A80 80 0 0 1 160 30" stroke="hsl(168, 55%, 45%)" stroke-width="12" fill="none" stroke-linecap="round" opacity="0.7"/>
    <!-- Needle -->
    <line x1="100" y1="100" x2="155" y2="38" stroke="hsl(210, 40%, 30%)" stroke-width="2" stroke-linecap="round"/>
    <circle cx="100" cy="100" r="5" fill="hsl(210, 40%, 30%)"/>
    <!-- Labels -->
    <text x="10" y="118" font-family="monospace" font-size="9" fill="hsl(210, 30%, 60%)">0</text>
    <text x="90" y="15" font-family="monospace" font-size="9" fill="hsl(210, 30%, 60%)" text-anchor="middle">Mbps</text>
    <text x="180" y="118" font-family="monospace" font-size="9" fill="hsl(210, 30%, 60%)">500+</text>
    <!-- Speed value -->
    <text x="100" y="85" font-family="system-ui, sans-serif" font-size="22" fill="hsl(168, 55%, 40%)" text-anchor="middle" font-weight="700">67</text>
    <text x="100" y="100" font-family="system-ui, sans-serif" font-size="9" fill="hsl(210, 30%, 55%)" text-anchor="middle">Mbps avg</text>
  </g>

  <!-- Connection type labels -->
  <g transform="translate(240, 160)">
    <rect x="0" y="0" width="55" height="18" rx="4" fill="hsl(168, 55%, 45%)" opacity="0.1"/>
    <text x="27" y="12" font-family="system-ui, sans-serif" font-size="7" fill="hsl(168, 55%, 40%)" text-anchor="middle" font-weight="600">Superfast</text>
    <rect x="65" y="0" width="55" height="18" rx="4" fill="hsl(168, 55%, 45%)" opacity="0.1"/>
    <text x="92" y="12" font-family="system-ui, sans-serif" font-size="7" fill="hsl(168, 55%, 40%)" text-anchor="middle" font-weight="600">Full Fibre</text>
    <rect x="130" y="0" width="55" height="18" rx="4" fill="hsl(168, 55%, 45%)" opacity="0.1"/>
    <text x="157" y="12" font-family="system-ui, sans-serif" font-size="7" fill="hsl(168, 55%, 40%)" text-anchor="middle" font-weight="600">Gigabit</text>
  </g>
</svg>
