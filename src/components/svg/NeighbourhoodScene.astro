---
/**
 * British neighbourhood street scene SVG — for the homepage hero.
 * Houses, trees, a red postbox, and rolling clouds. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 800 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-2xl mx-auto" role="img" aria-label="Illustration of a British neighbourhood with houses, trees and a red postbox">
  <!-- Sky gradient -->
  <defs>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 93%)"/>
    </linearGradient>
    <linearGradient id="grass" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(168, 55%, 45%)"/>
      <stop offset="100%" stop-color="hsl(168, 60%, 38%)"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="800" height="320" fill="url(#sky)"/>

  <!-- Clouds -->
  <g opacity="0.3">
    <ellipse cx="120" cy="60" rx="50" ry="18" fill="white"/>
    <ellipse cx="150" cy="55" rx="35" ry="14" fill="white"/>
    <ellipse cx="90" cy="55" rx="30" ry="12" fill="white"/>
    <ellipse cx="550" cy="45" rx="45" ry="16" fill="white"/>
    <ellipse cx="580" cy="40" rx="30" ry="12" fill="white"/>
    <ellipse cx="700" cy="70" rx="40" ry="14" fill="white"/>
  </g>

  <!-- Ground -->
  <rect x="0" y="240" width="800" height="80" fill="url(#grass)"/>
  <!-- Pavement -->
  <rect x="0" y="240" width="800" height="12" fill="hsl(210, 30%, 82%)" opacity="0.6"/>
  <!-- Road -->
  <rect x="0" y="252" width="800" height="20" fill="hsl(210, 20%, 55%)" opacity="0.3"/>
  <!-- Road markings -->
  <g opacity="0.5">
    <rect x="50" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="150" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="250" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="350" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="450" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="550" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="650" y="261" width="40" height="3" rx="1.5" fill="white"/>
    <rect x="750" y="261" width="40" height="3" rx="1.5" fill="white"/>
  </g>

  <!-- House 1 — Victorian terrace (left) -->
  <g transform="translate(40, 100)">
    <rect x="0" y="40" width="100" height="100" rx="2" fill="hsl(15, 55%, 55%)"/> <!-- Brick -->
    <rect x="0" y="36" width="100" height="8" fill="hsl(210, 50%, 18%)"/> <!-- Roof base -->
    <polygon points="0,40 50,10 100,40" fill="hsl(210, 45%, 26%)"/> <!-- Roof -->
    <rect x="15" y="65" width="22" height="30" rx="1" fill="hsl(210, 40%, 90%)"/> <!-- Window L -->
    <rect x="63" y="65" width="22" height="30" rx="1" fill="hsl(210, 40%, 90%)"/> <!-- Window R -->
    <rect x="17" y="80" width="18" height="1" fill="hsl(210, 30%, 72%)"/>
    <rect x="65" y="80" width="18" height="1" fill="hsl(210, 30%, 72%)"/>
    <rect x="38" y="100" width="24" height="40" rx="1" fill="hsl(168, 55%, 45%)"/> <!-- Door -->
    <circle cx="56" cy="122" r="2" fill="hsl(42, 70%, 50%)"/> <!-- Doorknob -->
    <rect x="44" y="55" width="12" height="6" rx="1" fill="hsl(210, 40%, 90%)"/> <!-- Attic window -->
    <!-- Chimney -->
    <rect x="75" y="12" width="12" height="24" fill="hsl(15, 45%, 45%)"/>
    <rect x="73" y="10" width="16" height="4" fill="hsl(15, 40%, 40%)"/>
  </g>

  <!-- House 2 — Semi-detached (centre-left) -->
  <g transform="translate(180, 110)">
    <rect x="0" y="30" width="120" height="100" rx="2" fill="hsl(40, 15%, 88%)"/> <!-- Render -->
    <polygon points="-5,34 60,0 125,34" fill="hsl(210, 45%, 26%)"/> <!-- Roof -->
    <rect x="15" y="55" width="25" height="28" rx="1" fill="hsl(210, 40%, 90%)"/>
    <rect x="80" y="55" width="25" height="28" rx="1" fill="hsl(210, 40%, 90%)"/>
    <rect x="17" y="68" width="21" height="1" fill="hsl(210, 30%, 72%)"/>
    <rect x="82" y="68" width="21" height="1" fill="hsl(210, 30%, 72%)"/>
    <rect x="47" y="90" width="26" height="40" rx="1" fill="hsl(210, 55%, 12%)"/> <!-- Door -->
    <rect x="49" y="92" width="10" height="14" rx="1" fill="hsl(210, 40%, 90%)" opacity="0.5"/>
    <!-- Garage -->
    <rect x="95" y="100" width="30" height="30" fill="hsl(40, 10%, 82%)"/>
    <rect x="97" y="102" width="26" height="26" rx="1" fill="hsl(210, 20%, 65%)" opacity="0.4"/>
    <!-- Chimney -->
    <rect x="85" y="2" width="10" height="22" fill="hsl(15, 55%, 55%)"/>
  </g>

  <!-- House 3 — Detached with garden (centre-right) -->
  <g transform="translate(360, 95)">
    <rect x="0" y="45" width="140" height="100" rx="2" fill="hsl(30, 20%, 85%)"/>
    <polygon points="-5,48 70,8 145,48" fill="hsl(0, 40%, 42%)"/> <!-- Red-brown roof -->
    <rect x="20" y="70" width="28" height="32" rx="1" fill="hsl(210, 40%, 90%)"/>
    <rect x="92" y="70" width="28" height="32" rx="1" fill="hsl(210, 40%, 90%)"/>
    <!-- Cross glazing bars -->
    <line x1="34" y1="70" x2="34" y2="102" stroke="hsl(210, 30%, 72%)" stroke-width="1"/>
    <line x1="20" y1="86" x2="48" y2="86" stroke="hsl(210, 30%, 72%)" stroke-width="1"/>
    <line x1="106" y1="70" x2="106" y2="102" stroke="hsl(210, 30%, 72%)" stroke-width="1"/>
    <line x1="92" y1="86" x2="120" y2="86" stroke="hsl(210, 30%, 72%)" stroke-width="1"/>
    <!-- Porch -->
    <rect x="55" y="108" width="30" height="37" rx="1" fill="hsl(168, 55%, 45%)"/>
    <rect x="52" y="105" width="36" height="6" fill="hsl(210, 45%, 26%)"/>
    <circle cx="79" cy="128" r="2" fill="hsl(42, 70%, 50%)"/>
    <!-- Bay window -->
    <polygon points="20,110 8,110 8,140 20,140" fill="hsl(30, 15%, 80%)"/>
    <rect x="9" y="112" width="10" height="26" fill="hsl(210, 40%, 90%)" opacity="0.7"/>
    <!-- Chimney -->
    <rect x="110" y="10" width="12" height="30" fill="hsl(15, 55%, 55%)"/>
    <rect x="108" y="8" width="16" height="4" fill="hsl(15, 40%, 40%)"/>
  </g>

  <!-- House 4 — Modern apartment block (right) -->
  <g transform="translate(560, 90)">
    <rect x="0" y="20" width="110" height="150" rx="3" fill="hsl(210, 35%, 45%)" opacity="0.15"/>
    <rect x="0" y="20" width="110" height="150" rx="3" fill="hsl(210, 40%, 35%)"/>
    <rect x="0" y="16" width="110" height="8" fill="hsl(210, 50%, 18%)"/>
    <!-- Windows grid -->
    <g fill="hsl(210, 40%, 90%)">
      <rect x="12" y="35" width="18" height="18" rx="1"/>
      <rect x="40" y="35" width="18" height="18" rx="1"/>
      <rect x="68" y="35" width="18" height="18" rx="1"/>
      <rect x="12" y="65" width="18" height="18" rx="1"/>
      <rect x="40" y="65" width="18" height="18" rx="1"/>
      <rect x="68" y="65" width="18" height="18" rx="1"/>
      <rect x="12" y="95" width="18" height="18" rx="1"/>
      <rect x="40" y="95" width="18" height="18" rx="1"/>
      <rect x="68" y="95" width="18" height="18" rx="1"/>
    </g>
    <!-- Some lit windows -->
    <rect x="40" y="35" width="18" height="18" rx="1" fill="hsl(42, 70%, 70%)" opacity="0.3"/>
    <rect x="12" y="95" width="18" height="18" rx="1" fill="hsl(42, 70%, 70%)" opacity="0.3"/>
    <!-- Entrance -->
    <rect x="40" y="135" width="30" height="35" rx="2" fill="hsl(210, 55%, 12%)"/>
    <rect x="96" y="35" width="8" height="135" fill="hsl(210, 35%, 40%)" opacity="0.3"/>
  </g>

  <!-- Tree 1 (between houses 1 & 2) -->
  <g transform="translate(155, 130)">
    <rect x="8" y="70" width="8" height="40" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="12" cy="55" rx="22" ry="28" fill="hsl(145, 40%, 42%)"/>
    <ellipse cx="20" cy="48" rx="15" ry="20" fill="hsl(150, 45%, 48%)"/>
  </g>

  <!-- Tree 2 (between houses 3 & 4) -->
  <g transform="translate(525, 120)">
    <rect x="7" y="65" width="7" height="35" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="10" cy="50" rx="18" ry="24" fill="hsl(145, 40%, 42%)"/>
    <ellipse cx="16" cy="44" rx="12" ry="16" fill="hsl(150, 45%, 48%)"/>
  </g>

  <!-- Tree 3 (far right) -->
  <g transform="translate(700, 140)">
    <rect x="6" y="55" width="6" height="30" fill="hsl(25, 40%, 35%)"/>
    <ellipse cx="9" cy="42" rx="16" ry="22" fill="hsl(145, 40%, 42%)"/>
  </g>

  <!-- Red Postbox -->
  <g transform="translate(315, 210)">
    <rect x="0" y="8" width="16" height="28" rx="2" fill="hsl(0, 70%, 45%)"/>
    <rect x="-1" y="6" width="18" height="4" rx="2" fill="hsl(0, 65%, 40%)"/>
    <ellipse cx="8" cy="6" rx="9" ry="6" fill="hsl(0, 70%, 45%)"/>
    <rect x="2" y="16" width="12" height="2" rx="1" fill="hsl(0, 60%, 35%)"/>
    <!-- Royal cypher suggestion -->
    <rect x="5" y="22" width="6" height="6" rx="1" fill="hsl(0, 60%, 55%)" opacity="0.5"/>
  </g>

  <!-- Garden fence (house 3) -->
  <g transform="translate(360, 235)" opacity="0.4">
    <rect x="0" y="0" width="2" height="8" fill="hsl(25, 40%, 50%)"/>
    <rect x="12" y="0" width="2" height="8" fill="hsl(25, 40%, 50%)"/>
    <rect x="24" y="0" width="2" height="8" fill="hsl(25, 40%, 50%)"/>
    <rect x="36" y="0" width="2" height="8" fill="hsl(25, 40%, 50%)"/>
    <rect x="0" y="2" width="38" height="1.5" fill="hsl(25, 40%, 50%)"/>
    <rect x="0" y="5" width="38" height="1.5" fill="hsl(25, 40%, 50%)"/>
  </g>
</svg>
