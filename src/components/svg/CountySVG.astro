---
/**
 * County / regional map-pin concept SVG — for county pages.
 * Abstract map outline with pinned location marker. Brand blue-slate + teal.
 */
---
<svg viewBox="0 0 400 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-sm mx-auto" role="img" aria-label="Illustration of a regional map with location pins">
  <defs>
    <linearGradient id="county-bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 93%)"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="400" height="240" rx="12" fill="url(#county-bg)"/>

  <!-- Abstract map shape (England-ish outline) -->
  <g transform="translate(100, 20)" opacity="0.12">
    <path d="M80 0 C95 5 110 15 115 30 L120 60 C125 80 130 95 120 110 L110 130 C105 145 95 155 90 170 L85 185 C80 195 70 200 60 195 L45 185 C35 175 25 160 20 145 L15 125 C10 105 5 85 10 65 L20 40 C30 20 55 5 80 0Z"
          fill="hsl(210, 35%, 60%)"/>
  </g>

  <!-- Grid lines (map-like) -->
  <g opacity="0.06" stroke="hsl(210, 30%, 50%)" stroke-width="0.5">
    <line x1="50" y1="0" x2="50" y2="240"/>
    <line x1="100" y1="0" x2="100" y2="240"/>
    <line x1="150" y1="0" x2="150" y2="240"/>
    <line x1="200" y1="0" x2="200" y2="240"/>
    <line x1="250" y1="0" x2="250" y2="240"/>
    <line x1="300" y1="0" x2="300" y2="240"/>
    <line x1="350" y1="0" x2="350" y2="240"/>
    <line x1="0" y1="40" x2="400" y2="40"/>
    <line x1="0" y1="80" x2="400" y2="80"/>
    <line x1="0" y1="120" x2="400" y2="120"/>
    <line x1="0" y1="160" x2="400" y2="160"/>
    <line x1="0" y1="200" x2="400" y2="200"/>
  </g>

  <!-- Postcode area dots -->
  <g opacity="0.15">
    <circle cx="145" cy="60" r="4" fill="hsl(168, 55%, 45%)"/>
    <circle cx="175" cy="85" r="5" fill="hsl(168, 55%, 45%)"/>
    <circle cx="160" cy="120" r="4" fill="hsl(168, 55%, 45%)"/>
    <circle cx="200" cy="95" r="3" fill="hsl(168, 55%, 45%)"/>
    <circle cx="130" cy="100" r="3" fill="hsl(168, 55%, 45%)"/>
    <circle cx="185" cy="140" r="4" fill="hsl(168, 55%, 45%)"/>
    <circle cx="155" cy="155" r="3" fill="hsl(168, 55%, 45%)"/>
    <circle cx="210" cy="130" r="3" fill="hsl(168, 55%, 45%)"/>
  </g>

  <!-- Main location pin -->
  <g transform="translate(200, 85)">
    <!-- Pin shadow -->
    <ellipse cx="0" cy="35" rx="10" ry="3" fill="hsl(210, 30%, 50%)" opacity="0.15"/>
    <!-- Pin body -->
    <path d="M0 -20 C-12 -20 -20 -10 -20 0 C-20 15 0 32 0 32 C0 32 20 15 20 0 C20 -10 12 -20 0 -20Z" fill="hsl(168, 55%, 45%)"/>
    <!-- Pin inner circle -->
    <circle cx="0" cy="-2" r="7" fill="white"/>
    <!-- Pin dot -->
    <circle cx="0" cy="-2" r="3" fill="hsl(168, 55%, 45%)"/>
  </g>

  <!-- Connecting lines from pin to data points -->
  <g stroke="hsl(168, 55%, 45%)" stroke-width="0.5" opacity="0.2" stroke-dasharray="3,3">
    <line x1="200" y1="100" x2="280" y2="70"/>
    <line x1="200" y1="100" x2="280" y2="110"/>
    <line x1="200" y1="100" x2="280" y2="150"/>
  </g>

  <!-- Data cards (right side) -->
  <g transform="translate(265, 55)">
    <rect x="0" y="0" width="110" height="28" rx="6" fill="white" stroke="hsl(210, 30%, 88%)" stroke-width="1"/>
    <circle cx="14" cy="14" r="5" fill="hsl(168, 55%, 45%)" opacity="0.2"/>
    <rect x="26" y="8" width="50" height="4" rx="2" fill="hsl(210, 30%, 80%)"/>
    <rect x="26" y="16" width="30" height="3" rx="1.5" fill="hsl(210, 30%, 88%)"/>
  </g>
  <g transform="translate(265, 95)">
    <rect x="0" y="0" width="110" height="28" rx="6" fill="white" stroke="hsl(210, 30%, 88%)" stroke-width="1"/>
    <circle cx="14" cy="14" r="5" fill="hsl(168, 55%, 45%)" opacity="0.2"/>
    <rect x="26" y="8" width="45" height="4" rx="2" fill="hsl(210, 30%, 80%)"/>
    <rect x="26" y="16" width="35" height="3" rx="1.5" fill="hsl(210, 30%, 88%)"/>
  </g>
  <g transform="translate(265, 135)">
    <rect x="0" y="0" width="110" height="28" rx="6" fill="white" stroke="hsl(210, 30%, 88%)" stroke-width="1"/>
    <circle cx="14" cy="14" r="5" fill="hsl(168, 55%, 45%)" opacity="0.2"/>
    <rect x="26" y="8" width="55" height="4" rx="2" fill="hsl(210, 30%, 80%)"/>
    <rect x="26" y="16" width="25" height="3" rx="1.5" fill="hsl(210, 30%, 88%)"/>
  </g>

  <!-- Label -->
  <text x="200" y="225" font-family="system-ui, sans-serif" font-size="11" fill="hsl(210, 30%, 60%)" text-anchor="middle" font-weight="500">Postcode districts in this county</text>
</svg>
