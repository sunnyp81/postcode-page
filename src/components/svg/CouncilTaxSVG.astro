---
/**
 * Council Tax SVG — a council building with pound sign and banding bars.
 * For the council tax blog post. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 600 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-md mx-auto" role="img" aria-label="Illustration representing council tax with a civic building and tax bands">
  <defs>
    <linearGradient id="ct-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 94%)"/>
    </linearGradient>
  </defs>

  <rect width="600" height="200" rx="12" fill="url(#ct-bg)"/>

  <!-- Civic building -->
  <g transform="translate(60, 30)">
    <!-- Columns -->
    <rect x="15" y="50" width="12" height="70" fill="hsl(210, 30%, 78%)"/>
    <rect x="43" y="50" width="12" height="70" fill="hsl(210, 30%, 78%)"/>
    <rect x="71" y="50" width="12" height="70" fill="hsl(210, 30%, 78%)"/>
    <rect x="99" y="50" width="12" height="70" fill="hsl(210, 30%, 78%)"/>
    <!-- Pediment -->
    <polygon points="0,52 63,20 126,52" fill="hsl(210, 35%, 70%)"/>
    <rect x="0" y="48" width="126" height="6" fill="hsl(210, 30%, 75%)"/>
    <!-- Base -->
    <rect x="0" y="118" width="126" height="8" fill="hsl(210, 30%, 75%)"/>
    <!-- Steps -->
    <rect x="-5" y="126" width="136" height="4" fill="hsl(210, 25%, 82%)"/>
    <rect x="-10" y="130" width="146" height="4" fill="hsl(210, 25%, 85%)"/>
    <!-- Door -->
    <rect x="48" y="85" width="30" height="33" rx="15" fill="hsl(210, 45%, 28%)"/>
    <!-- Clock -->
    <circle cx="63" cy="38" r="8" fill="white" stroke="hsl(210, 30%, 65%)" stroke-width="1"/>
    <line x1="63" y1="38" x2="63" y2="33" stroke="hsl(210, 30%, 50%)" stroke-width="1"/>
    <line x1="63" y1="38" x2="67" y2="40" stroke="hsl(210, 30%, 50%)" stroke-width="1"/>
  </g>

  <!-- Pound sign -->
  <g transform="translate(275, 45)">
    <circle cx="25" cy="25" r="25" fill="hsl(168, 55%, 45%)" opacity="0.1"/>
    <text x="25" y="34" font-family="system-ui, sans-serif" font-size="28" fill="hsl(168, 55%, 45%)" text-anchor="middle" font-weight="700">£</text>
  </g>

  <!-- Tax band bars (A-H) -->
  <g transform="translate(350, 30)">
    <text x="0" y="10" font-family="system-ui, sans-serif" font-size="9" fill="hsl(210, 30%, 55%)" font-weight="600">COUNCIL TAX BANDS</text>
    <g transform="translate(0, 18)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">A</text>
      <rect x="18" y="3" width="60" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.25"/>
    </g>
    <g transform="translate(0, 34)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">B</text>
      <rect x="18" y="3" width="75" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.3"/>
    </g>
    <g transform="translate(0, 50)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">C</text>
      <rect x="18" y="3" width="90" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.35"/>
    </g>
    <g transform="translate(0, 66)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 60%)" font-weight="700">D</text>
      <rect x="18" y="3" width="105" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.5"/>
    </g>
    <g transform="translate(0, 82)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">E</text>
      <rect x="18" y="3" width="125" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.4"/>
    </g>
    <g transform="translate(0, 98)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">F</text>
      <rect x="18" y="3" width="145" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.45"/>
    </g>
    <g transform="translate(0, 114)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">G</text>
      <rect x="18" y="3" width="165" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.5"/>
    </g>
    <g transform="translate(0, 130)">
      <text x="0" y="10" font-family="monospace" font-size="9" fill="hsl(210, 30%, 55%)">H</text>
      <rect x="18" y="3" width="190" height="8" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.55"/>
    </g>
  </g>
</svg>
