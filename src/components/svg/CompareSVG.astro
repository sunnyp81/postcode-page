---
/**
 * Compare SVG — two houses side-by-side with vs divider.
 * For compare pages. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 600 220" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg mx-auto" role="img" aria-label="Illustration comparing two houses side by side">
  <defs>
    <linearGradient id="cmp-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 93%)"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="600" height="220" fill="url(#cmp-sky)"/>

  <!-- Ground -->
  <rect x="0" y="175" width="600" height="45" fill="hsl(130, 35%, 50%)" opacity="0.15"/>

  <!-- Left house — Victorian terrace -->
  <g transform="translate(60, 55)">
    <rect x="0" y="35" width="100" height="85" rx="2" fill="hsl(15, 55%, 55%)"/>
    <polygon points="0,38 50,10 100,38" fill="hsl(210, 45%, 26%)"/>
    <!-- Windows -->
    <rect x="12" y="50" width="22" height="28" rx="1" fill="hsl(210, 40%, 92%)"/>
    <rect x="66" y="50" width="22" height="28" rx="1" fill="hsl(210, 40%, 92%)"/>
    <line x1="23" y1="50" x2="23" y2="78" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <line x1="77" y1="50" x2="77" y2="78" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <!-- Door -->
    <rect x="38" y="85" width="24" height="35" rx="1" fill="hsl(168, 55%, 42%)"/>
    <circle cx="56" cy="104" r="2" fill="hsl(42, 70%, 50%)"/>
    <!-- Chimney -->
    <rect x="75" y="12" width="10" height="22" fill="hsl(15, 45%, 45%)"/>
    <!-- Garden -->
    <rect x="-8" y="118" width="116" height="6" rx="3" fill="hsl(140, 35%, 40%)" opacity="0.5"/>
  </g>

  <!-- VS divider -->
  <line x1="300" y1="30" x2="300" y2="175" stroke="hsl(210, 25%, 82%)" stroke-width="1" stroke-dasharray="4,4"/>
  <circle cx="300" cy="100" r="18" fill="white" stroke="hsl(168, 55%, 45%)" stroke-width="2"/>
  <text x="300" y="105" font-family="system-ui, sans-serif" font-size="12" fill="hsl(168, 55%, 45%)" text-anchor="middle" font-weight="700">VS</text>

  <!-- Right house — Modern detached -->
  <g transform="translate(370, 50)">
    <rect x="0" y="30" width="120" height="95" rx="3" fill="hsl(210, 15%, 82%)"/>
    <rect x="0" y="26" width="120" height="8" fill="hsl(210, 30%, 35%)"/>
    <!-- Large windows -->
    <rect x="10" y="42" width="35" height="30" rx="2" fill="hsl(210, 40%, 92%)"/>
    <rect x="75" y="42" width="35" height="30" rx="2" fill="hsl(210, 40%, 92%)"/>
    <!-- Door -->
    <rect x="47" y="90" width="26" height="35" rx="2" fill="hsl(168, 50%, 40%)"/>
    <rect x="49" y="92" width="10" height="14" rx="1" fill="hsl(210, 40%, 92%)" opacity="0.5"/>
    <!-- Garage -->
    <rect x="95" y="95" width="30" height="30" fill="hsl(210, 12%, 78%)"/>
    <rect x="97" y="97" width="26" height="26" rx="1" fill="hsl(210, 20%, 65%)" opacity="0.35"/>
    <!-- Garden -->
    <rect x="-8" y="123" width="140" height="6" rx="3" fill="hsl(140, 35%, 40%)" opacity="0.5"/>
  </g>

  <!-- Data comparison bars at bottom -->
  <g transform="translate(60, 190)">
    <rect x="0" y="0" width="180" height="5" rx="2.5" fill="hsl(168, 55%, 45%)" opacity="0.3"/>
    <rect x="0" y="0" width="120" height="5" rx="2.5" fill="hsl(168, 55%, 45%)" opacity="0.6"/>
  </g>
  <g transform="translate(360, 190)">
    <rect x="0" y="0" width="180" height="5" rx="2.5" fill="hsl(168, 55%, 45%)" opacity="0.3"/>
    <rect x="0" y="0" width="150" height="5" rx="2.5" fill="hsl(168, 55%, 45%)" opacity="0.6"/>
  </g>
</svg>
