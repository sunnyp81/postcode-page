---
/**
 * First-Time Buyer SVG — a couple with a key and a house.
 * For the first-time buyer blog post. Brand blue-slate + teal accent.
 */
---
<svg viewBox="0 0 600 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-md mx-auto" role="img" aria-label="Illustration of first-time buyers receiving house keys">
  <defs>
    <linearGradient id="ftb-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="hsl(210, 40%, 97%)"/>
      <stop offset="100%" stop-color="hsl(210, 38%, 94%)"/>
    </linearGradient>
  </defs>

  <rect width="600" height="200" rx="12" fill="url(#ftb-bg)"/>

  <!-- House -->
  <g transform="translate(350, 30)">
    <rect x="0" y="40" width="140" height="100" rx="3" fill="hsl(15, 50%, 60%)"/>
    <polygon points="-5,43 70,5 145,43" fill="hsl(210, 45%, 26%)"/>
    <!-- Windows -->
    <rect x="15" y="58" width="30" height="28" rx="2" fill="hsl(210, 40%, 92%)"/>
    <rect x="95" y="58" width="30" height="28" rx="2" fill="hsl(210, 40%, 92%)"/>
    <line x1="30" y1="58" x2="30" y2="86" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <line x1="15" y1="72" x2="45" y2="72" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <line x1="110" y1="58" x2="110" y2="86" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <line x1="95" y1="72" x2="125" y2="72" stroke="hsl(210, 30%, 75%)" stroke-width="0.8"/>
    <!-- Door -->
    <rect x="55" y="100" width="30" height="40" rx="2" fill="hsl(168, 55%, 42%)"/>
    <circle cx="79" cy="122" r="2.5" fill="hsl(42, 70%, 50%)"/>
    <!-- Chimney -->
    <rect x="110" y="8" width="12" height="28" fill="hsl(15, 45%, 50%)"/>
    <!-- SOLD sign -->
    <g transform="translate(-20, 70)">
      <rect x="0" y="0" width="3" height="40" fill="hsl(25, 30%, 50%)"/>
      <rect x="-10" y="-2" width="28" height="16" rx="2" fill="hsl(0, 65%, 50%)"/>
      <text x="4" y="9" font-family="system-ui, sans-serif" font-size="7" fill="white" font-weight="700">SOLD</text>
    </g>
  </g>

  <!-- Key icon (centre) -->
  <g transform="translate(230, 60)">
    <circle cx="30" cy="30" r="30" fill="hsl(168, 55%, 45%)" opacity="0.1"/>
    <!-- Key shape -->
    <g transform="translate(14, 18)">
      <circle cx="8" cy="8" r="7" fill="none" stroke="hsl(42, 65%, 50%)" stroke-width="2.5"/>
      <rect x="14" y="6" width="20" height="4" rx="1" fill="hsl(42, 65%, 50%)"/>
      <rect x="28" y="10" width="3" height="6" rx="1" fill="hsl(42, 65%, 50%)"/>
      <rect x="23" y="10" width="3" height="5" rx="1" fill="hsl(42, 65%, 50%)"/>
    </g>
  </g>

  <!-- Checklist on left -->
  <g transform="translate(40, 35)">
    <rect x="0" y="0" width="140" height="130" rx="8" fill="white" stroke="hsl(210, 30%, 88%)" stroke-width="1"/>
    <text x="14" y="22" font-family="system-ui, sans-serif" font-size="10" fill="hsl(210, 35%, 40%)" font-weight="600">Research checklist</text>
    <line x1="14" y1="28" x2="126" y2="28" stroke="hsl(210, 30%, 90%)" stroke-width="0.5"/>

    <!-- Check items -->
    <g transform="translate(14, 38)">
      <rect x="0" y="0" width="10" height="10" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.15"/>
      <path d="M2 5 L4 7 L8 3" stroke="hsl(168, 55%, 45%)" stroke-width="1.5" fill="none"/>
      <text x="16" y="9" font-family="system-ui, sans-serif" font-size="8" fill="hsl(210, 30%, 55%)">House prices</text>
    </g>
    <g transform="translate(14, 56)">
      <rect x="0" y="0" width="10" height="10" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.15"/>
      <path d="M2 5 L4 7 L8 3" stroke="hsl(168, 55%, 45%)" stroke-width="1.5" fill="none"/>
      <text x="16" y="9" font-family="system-ui, sans-serif" font-size="8" fill="hsl(210, 30%, 55%)">Crime rates</text>
    </g>
    <g transform="translate(14, 74)">
      <rect x="0" y="0" width="10" height="10" rx="2" fill="hsl(168, 55%, 45%)" opacity="0.15"/>
      <path d="M2 5 L4 7 L8 3" stroke="hsl(168, 55%, 45%)" stroke-width="1.5" fill="none"/>
      <text x="16" y="9" font-family="system-ui, sans-serif" font-size="8" fill="hsl(210, 30%, 55%)">School ratings</text>
    </g>
    <g transform="translate(14, 92)">
      <rect x="0" y="0" width="10" height="10" rx="2" fill="hsl(210, 30%, 88%)" opacity="0.3"/>
      <text x="16" y="9" font-family="system-ui, sans-serif" font-size="8" fill="hsl(210, 30%, 65%)">Broadband speed</text>
    </g>
    <g transform="translate(14, 110)">
      <rect x="0" y="0" width="10" height="10" rx="2" fill="hsl(210, 30%, 88%)" opacity="0.3"/>
      <text x="16" y="9" font-family="system-ui, sans-serif" font-size="8" fill="hsl(210, 30%, 65%)">Council tax</text>
    </g>
  </g>
</svg>
