---
const currentYear = new Date().getFullYear();

const regions = [
  { label: 'South East', href: '/regions/south-east/' },
  { label: 'London', href: '/regions/london/' },
  { label: 'East of England', href: '/regions/east-of-england/' },
  { label: 'East Midlands', href: '/regions/east-midlands/' },
  { label: 'South West', href: '/regions/south-west/' },
  { label: 'Yorkshire', href: '/regions/yorkshire/' },
  { label: 'All Regions', href: '/regions/' },
];

const tools = [
  { label: 'Area Research Tools', href: '/tools/' },
];

const guides = [
  { label: 'Property Guides', href: '/guides/' },
];
---

<footer class="bg-brand-900 text-brand-300 mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <!-- Main grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-10">

      <!-- Brand -->
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-3">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="7" fill="hsl(168, 55%, 45%)"/>
            <rect x="7" y="7" width="8" height="8" rx="2" fill="white"/>
            <rect x="17" y="7" width="8" height="8" rx="2" fill="white" opacity="0.7"/>
            <rect x="7" y="17" width="8" height="8" rx="2" fill="white" opacity="0.7"/>
            <rect x="17" y="17" width="8" height="8" rx="2" fill="white" opacity="0.4"/>
          </svg>
          <span class="font-display font-700 text-white text-sm">Postcode<span class="text-accent-400">.Page</span></span>
        </a>
        <p class="text-sm leading-relaxed text-brand-400">
          Property prices, crime, schools, and demographics for every UK postcode.
        </p>
        <p class="text-xs text-brand-500 mt-3">Updated monthly from official sources.</p>
      </div>

      <!-- Regions -->
      <div>
        <h3 class="text-white font-600 text-sm mb-3">Regions</h3>
        <ul class="space-y-1.5">
          {regions.map(r => (
            <li><a href={r.href} class="text-sm text-brand-400 hover:text-white transition-colors">{r.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3 class="text-white font-600 text-sm mb-3">Tools</h3>
        <ul class="space-y-1.5">
          {tools.map(t => (
            <li><a href={t.href} class="text-sm text-brand-400 hover:text-white transition-colors">{t.label}</a></li>
          ))}
        </ul>

        <h3 class="text-white font-600 text-sm mt-6 mb-3">Guides</h3>
        <ul class="space-y-1.5">
          {guides.map(g => (
            <li><a href={g.href} class="text-sm text-brand-400 hover:text-white transition-colors">{g.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Data & Legal -->
      <div>
        <h3 class="text-white font-600 text-sm mb-3">Data Sources</h3>
        <ul class="space-y-1.5">
          <li><a href="/methodology/" class="text-sm text-brand-400 hover:text-white transition-colors">HM Land Registry</a></li>
          <li><a href="/methodology/" class="text-sm text-brand-400 hover:text-white transition-colors">data.police.uk</a></li>
          <li><a href="/methodology/" class="text-sm text-brand-400 hover:text-white transition-colors">DfE Schools Data</a></li>
          <li><a href="/methodology/" class="text-sm text-brand-400 hover:text-white transition-colors">ONS Census 2021</a></li>
          <li><a href="/methodology/" class="text-sm text-brand-400 hover:text-white transition-colors">Our Methodology</a></li>
        </ul>

        <h3 class="text-white font-600 text-sm mt-6 mb-3">Legal</h3>
        <ul class="space-y-1.5">
          <li><a href="/privacy/" class="text-sm text-brand-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-brand-400 hover:text-white transition-colors">Terms of Use</a></li>
          <li><a href="/about/" class="text-sm text-brand-400 hover:text-white transition-colors">About</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-brand-800 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs text-brand-500">
      <p>© {currentYear} Postcode.Page. Contains HM Land Registry data © Crown copyright and database right 2025. Open Government Licence v3.0.</p>
      <p>Data for England &amp; Wales.</p>
    </div>

  </div>
</footer>
