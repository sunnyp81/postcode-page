---
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-brand-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="postcode.page home">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="28" height="28" rx="6" fill="hsl(168, 55%, 45%)"/>
        <text x="4" y="20" font-family="JetBrains Mono, monospace" font-size="13" font-weight="700" fill="white">PC</text>
      </svg>
      <span class="font-display font-700 text-brand-900 text-sm tracking-tight">postcode<span class="text-accent-400">.page</span></span>
    </a>

    <!-- Inline search (desktop) -->
    <form action="/search" method="get" class="hidden sm:flex flex-1 max-w-xs" role="search">
      <label for="header-search" class="sr-only">Search postcodes</label>
      <div class="relative w-full">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="header-search"
          type="search"
          name="q"
          placeholder="Enter a postcode (e.g. SW1A)"
          autocomplete="off"
          class="w-full pl-9 pr-4 py-2 text-sm bg-brand-50 border border-brand-200 rounded-lg text-brand-800 placeholder:text-brand-400 focus:outline-none focus:ring-2 focus:ring-accent-400 focus:border-transparent transition-colors"
        />
      </div>
    </form>

    <!-- Nav -->
    <nav class="flex items-center gap-1" aria-label="Main navigation">
      <a href="/guides/" class="hidden sm:block px-3 py-1.5 text-sm text-brand-600 hover:text-brand-900 hover:bg-brand-50 rounded-lg transition-colors">Guides</a>
      <a href="/tools/" class="hidden sm:block px-3 py-1.5 text-sm text-brand-600 hover:text-brand-900 hover:bg-brand-50 rounded-lg transition-colors">Tools</a>
      <a href="/regions/" class="hidden sm:block px-3 py-1.5 text-sm text-brand-600 hover:text-brand-900 hover:bg-brand-50 rounded-lg transition-colors">Regions</a>

      <!-- Mobile search button -->
      <button class="sm:hidden p-2 text-brand-600 hover:text-brand-900 hover:bg-brand-50 rounded-lg transition-colors" aria-label="Search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </button>
    </nav>

  </div>
</header>
