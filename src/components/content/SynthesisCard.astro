---
interface Tag {
  label: string;
  value: string;
  sentiment: 'positive' | 'negative' | 'neutral';
}
interface Props {
  code: string;
  name: string;
  summary: string;
  tags: Tag[];
}
const { code, name, summary, tags } = Astro.props;

const sentimentStyle = {
  positive: 'bg-accent-400/10 text-accent-600 border-accent-400/30',
  negative: 'bg-brand-100 text-brand-700 border-brand-200',
  neutral: 'bg-brand-50 text-brand-600 border-brand-100',
};
---

<div class="card p-6 border-l-4 border-accent-400">
  <div class="flex items-start gap-4 mb-4">
    <div class="shrink-0 w-12 h-12 rounded-lg bg-accent-400/10 border border-accent-400/20 flex items-center justify-center">
      <span class="font-mono font-700 text-accent-500 text-xs">{code.slice(0, 2)}</span>
    </div>
    <div>
      <p class="font-600 text-brand-900">{code} — {name}</p>
      <p class="text-sm text-brand-500">Area Summary</p>
    </div>
  </div>

  <p class="text-brand-700 leading-relaxed mb-5">{summary}</p>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
    {tags.map(tag => (
      <div class={`rounded-lg border px-3 py-2 text-center ${sentimentStyle[tag.sentiment]}`}>
        <p class="text-xs font-600 uppercase tracking-wide opacity-70">{tag.label}</p>
        <p class="text-sm font-600 mt-0.5">{tag.value}</p>
      </div>
    ))}
  </div>
</div>
