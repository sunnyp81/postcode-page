---
interface Props {
  label: string;
  value: string;
  change?: number;     // percentage change, positive = up, negative = down
  changeLabel?: string; // e.g. "vs last year"
  context?: string;    // e.g. "national avg £287,000"
  contextPct?: number; // % above/below comparison (positive = above)
  tooltip?: string;
}

const { label, value, change, changeLabel = 'vs last year', context, contextPct, tooltip } = Astro.props;

const hasChange = change !== undefined;
const isUp = hasChange && change > 0;
const isDown = hasChange && change < 0;
const changeClass = isUp ? 'trend-up' : isDown ? 'trend-down' : 'trend-neutral';
const changeSign = isUp ? '▲' : isDown ? '▼' : '—';
const changeAbs = hasChange ? Math.abs(change).toFixed(1) : null;

const contextUp = contextPct !== undefined && contextPct > 0;
const contextDown = contextPct !== undefined && contextPct < 0;
---

<div class="card p-5 flex flex-col gap-3">
  <!-- Label row -->
  <div class="flex items-center justify-between">
    <span class="text-xs font-600 uppercase tracking-widest text-brand-400">{label}</span>
    {tooltip && (
      <button
        class="text-brand-300 hover:text-brand-600 transition-colors"
        title={tooltip}
        aria-label={`Info: ${tooltip}`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke-width="2"/>
          <path stroke-linecap="round" stroke-width="2" d="M12 16v-4M12 8h.01"/>
        </svg>
      </button>
    )}
  </div>

  <!-- Primary value -->
  <div>
    <p class="font-mono text-2xl font-700 text-brand-900 leading-none">{value}</p>
    {hasChange && (
      <p class={`mt-1 text-sm font-500 ${changeClass}`}>
        {changeSign} {changeAbs}% <span class="text-brand-400 font-400">{changeLabel}</span>
      </p>
    )}
  </div>

  <!-- Comparison bar -->
  {context && contextPct !== undefined && (
    <div class="mt-auto pt-3 border-t border-brand-100">
      <div class="flex items-center justify-between text-xs text-brand-400 mb-1.5">
        <span>This area</span>
        <span>{context}</span>
      </div>
      <div class="relative h-1.5 bg-brand-100 rounded-full overflow-hidden">
        {contextUp && (
          <div
            class="absolute right-0 top-0 h-full bg-accent-400 rounded-full"
            style={`width: ${Math.min(Math.abs(contextPct), 100)}%`}
          />
        )}
        {contextDown && (
          <div
            class="absolute left-0 top-0 h-full bg-down rounded-full"
            style={`width: ${Math.min(Math.abs(contextPct), 100)}%`}
          />
        )}
        <div class="absolute left-1/2 top-0 w-px h-full bg-brand-300" />
      </div>
      <p class={`text-xs mt-1 font-500 ${contextUp ? 'trend-up' : contextDown ? 'trend-down' : 'trend-neutral'}`}>
        {contextPct > 0 ? `${contextPct.toFixed(0)}% above` : `${Math.abs(contextPct).toFixed(0)}% below`} national avg
      </p>
    </div>
  )}
</div>
