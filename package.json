{
  "name": "postcode-page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "pipeline": "node pipeline/run-all.mjs",
    "pipeline:download": "node pipeline/01-download.mjs",
    "pipeline:parse": "node pipeline/02-parse-land-registry.mjs && node pipeline/03-parse-crime.mjs && node pipeline/04-parse-schools.mjs",
    "pipeline:aggregate": "node pipeline/09-aggregate.mjs",
    "pipeline:context": "node pipeline/11-generate-context.mjs",
    "deploy": "astro build && npx wrangler pages deploy dist --project-name postcode-page --commit-dirty=true"
  },
  "dependencies": {
    "@astrojs/preact": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.0",
    "preact": "^10.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "sharp": "^0.33.0",
    "typescript": "^5.0.0"
  }
}
